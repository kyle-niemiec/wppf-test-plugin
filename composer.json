{
    "description": "Reference implementation and demonstration plugin for the WordPress Plugin Framework (WPPF), showcasing modules, custom post types, structured meta, WooCommerce integration, and upgrade routines.",
    "keywords": [
        "wordpress",
        "wordpress-plugin",
        "plugin-example",
        "reference-implementation",
        "wppf",
        "plugin-framework",
        "woocommerce",
        "wordpress-development"
    ],
    "require": {
        "kyle-niemiec/wppf-update-helper": "^1.0",
        "kyle-niemiec/wp-plugin-framework": "^1.2"
    },
    "scripts": {
        "build": [
            "rm -rf ./build",
            "mkdir -p ./build/src",
            "composer install",
            "rsync -r --exclude-from=.distignore ./ ./build/src",
            "zip -r ./build/wppf-test-plugin.zip ./build/src",
            "(cd ./build/src ; zip -r ../wppf-test-plugin.zip ./)"
        ]
    }
}
